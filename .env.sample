# Values interpolated into docker-compose.yml (x-backend-variables), which
# declares every variable the services receive. Internal hosts (DB, Redis,
# MQTT broker) are pinned to compose service names there and are not
# configurable here.

# --- Required ---
SECRET_KEY=change-me
DB_PASSWORD=change-me
MQTT_CONSUMER_PASSWORD=change-me
# Fernet key for encrypting stored credentials:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CAPAGG_SECRET_KEY=

# --- Django ---
# The dev overlay (docker-compose.dev.yml) overrides these to dev settings
DJANGO_SETTINGS_MODULE=capaggregator.config.settings.production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
# Every public URL the site is served from, with scheme (dev settings default
# to the localhost origins below when this is empty)
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8000,http://127.0.0.1:8000
WAGTAILADMIN_BASE_URL=http://localhost:8000

# --- Database ---
# Interpolated into DATABASE_URL in docker-compose.yml (postgis:// scheme)
DB_NAME=capagg
DB_USER=capagg
DB_CONNECTION_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=False
DB_DISABLE_SERVER_SIDE_CURSORS=False
DB_SSL_REQUIRE=False

# --- MQTT ---
MQTT_CONSUMER_USERNAME=capagg-consumer
MQTT_IN_TOPIC=cap/in/#
MOSQUITTO_UID=1883

# --- Celery ---
CAPAGG_CELERY_DEFAULT_WORKER_CONCURRENCY=2
CAPAGG_CELERY_INGESTION_WORKER_CONCURRENCY=2
CAPAGG_CELERY_WORKER_LOG_LEVEL=INFO

# --- Gunicorn ---
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120

# --- Host ports ---
APP_PORT=8000
WEB_PORT=8080
MQTT_PORT=1883
MARTIN_PORT=3000

# Shared external docker network (only with docker-compose.override.yml; see its .sample)
#NETWORK_NAME=cap
